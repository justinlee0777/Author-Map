{
  "name": "author-map-ui",
  "version": "0.0.0-beta.25",
  "type": "module",
  "scripts": {
    "start": "rm -rf .parcel-cache && parcel index.html",
    "format": "prettier -w .",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "build": "rm -rf dist && vite build && node ./post-vite.js"
  },
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./index.js",
      "types": "./index.d.ts"
    },
    "./models": {
      "import": "./models.js",
      "require": "./models.js",
      "types": "./models.d.ts"
    },
    "./author-map-ui.css": "./author-map-ui.css"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "formik": "^2.4.6",
    "lodash-es": "^4.17.21",
    "mathjs": "^15.2.0",
    "react-icons": "^5.5.0",
    "react-modal": "^3.16.3",
    "react-simple-maps": "^3.0.0",
    "react-spinners": "^0.17.0",
    "react-tooltip": "^5.29.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^26.1.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@types/react-modal": "^3.16.3",
    "@types/react-simple-maps": "^3.0.6",
    "@vitejs/plugin-react": "^6.0.3",
    "jest-environment-jsdom": "^30.2.0",
    "parcel": "^2.15.4",
    "prettier": "^3.6.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "overrides": {
    "react-simple-maps": {
      "d3-zoom": "^3.0.0",
      "d3-interpolate": "^3.0.1",
      "d3-color": "^3.1.0",
      "d3-geo": "^3.1.0",
      "d3-selection": "^3.0.0",
      "react": "^16.8.0 || 17.x || 18.x || 19.x",
      "react-dom": "^16.8.0 || 17.x || 18.x || 19.x"
    }
  }
}
